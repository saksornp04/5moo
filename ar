            // หมู่ 3
            { name: "บลอกโคลี", group: 3, emoji: "🥦" },
            { name: "มะเขือเทศ", group: 3, emoji: "🍅" },
            { name: "แครอท", group: 3, emoji: "🥕" },
            { name: "ผักกาดหอม", group: 3, emoji: "🥬" },
            { name: "ฟักทอง", group: 3, emoji: "🎃" },
            // หมู่ 4
            { name: "แอปเปิ้ล", group: 4, emoji: "🍎" },
            { name: "กล้วยหอม", group: 4, emoji: "🍌" },
            { name: "ส้มหวาน", group: 4, emoji: "🍊" },
            { name: "แตงโม", group: 4, emoji: "🍉" },
            { name: "สตรอว์เบอร์รี", group: 4, emoji: "🍓" },
            // หมู่ 5
            { name: "เนย", group: 5, emoji: "🧈" },
            { name: "น้ำมันพืช", group: 5, emoji: "🥥" },
            { name: "ชีสแผ่น", group: 5, emoji: "🧀" },
